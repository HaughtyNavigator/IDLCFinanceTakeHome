# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional. How many independent extractions to run per request; a field is
# only returned if a majority of the samples agree on it. 1 disables the
# check. Clamped to 1..5.
# EXTRACTION_SAMPLES=3

# Optional, LOCAL DEBUGGING ONLY. Include the extracted values (name, NID
# number, address) in the per-field consensus log lines. These are personal
# data, so leave this off anywhere the logs are collected or shared.
# CONSENSUS_LOG_VALUES=false
